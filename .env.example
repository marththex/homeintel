# HomeIntel — environment template
#
# Copy this file to `.env` (repo root) and adjust values for your machine:
#   cp .env.example .env
#
# Every setting below maps 1:1 to a field in backend/config.py (same section
# order). List-type settings (SUPPORTED_EXTENSIONS, WATCHER_EXCLUDE_PATHS,
# CORS_ALLOW_ORIGINS) are plain comma-separated strings, not JSON arrays.

# ── Folder to index ─────────────────────────────────────────────────────────────
# NAS_WATCH_PATH is just "the folder HomeIntel indexes and watches for changes".
# Despite the name (kept for backwards compatibility), it does NOT have to be a
# NAS — any local folder works. Defaults to the bundled sample docs so the app
# runs out-of-the-box after setup. Point it at a mounted NAS share (SMB/NFS) or
# any other directory once you're ready to index your own files. Relative paths
# resolve against the repository root (not the process's current working
# directory), so this default works regardless of where you launch the backend
# from (e.g. `cd backend && uvicorn main:app`).
NAS_WATCH_PATH=./data/sample-docs
SUPPORTED_EXTENSIONS=.pdf,.docx,.txt,.md,.yml,.yaml,.json,.png,.jpg,.jpeg,.mp3,.wav
# Comma-separated absolute paths to skip (e.g. cache/build dirs, other apps'
# data folders living under the watched root). Leave empty to watch everything
# under NAS_WATCH_PATH. Example: WATCHER_EXCLUDE_PATHS=/path/to/exclude/one,/path/to/exclude/two
WATCHER_EXCLUDE_PATHS=

# ── Qdrant (vector store) ────────────────────────────────────────────────────────
# Point this at wherever you're running Qdrant (docker/qdrant.yml) — localhost,
# another machine on your LAN, or a NAS. See docker/qdrant.yml for a standalone
# Docker Compose you can deploy anywhere reachable over the network.
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=homeintel
# Leave empty for no-auth setups.
QDRANT_API_KEY=
EMBED_DIM=768

# ── Reranker ──────────────────────────────────────────────────────────────────────
RERANKER_ENABLED=true
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# Image queries only: drop photos below this reranker relevance (0..1). Higher = stricter.
IMAGE_RERANK_MIN_SCORE=0.3

# ── Docling VLM enrichment (optional) ────────────────────────────────────────────
# Adds VLM-generated picture descriptions during PDF/DOCX ingestion via Docling.
# Off by default — can be VRAM-heavy alongside the main LLM. See README for notes.
DOCLING_VLM_ENABLED=false
DOCLING_VLM_MODEL=Qwen/Qwen2.5-VL-7B-Instruct

# ── Ollama ────────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434   # use http://host.docker.internal:11434 from inside Docker
OLLAMA_LLM_MODEL=qwen3.5:9b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── RAG ───────────────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
RETRIEVAL_TOP_K=6

# ── API ───────────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info
# Comma-separated list of allowed frontend origins for CORS.
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Image ingestion (optional) ───────────────────────────────────────────────────
# Set to a vision-capable Ollama model to enable image captioning.
# Leave empty to skip image files entirely.
# Example: OLLAMA_VISION_MODEL=qwen2.5vl:7b
OLLAMA_VISION_MODEL=

# ── Audio ingestion ───────────────────────────────────────────────────────────────
# faster-whisper model size: tiny|base|small|medium|large-v3
WHISPER_MODEL_SIZE=base

# ── ColPali visual retrieval (optional) ──────────────────────────────────────────
# Run scripts/run_colpali.py to batch-index PDF pages, then set COLPALI_ENABLED=true.
# Requires: pip install colpali-engine>=0.3.0 pypdfium2>=4.0.0 (see requirements.txt)
COLPALI_ENABLED=false
COLPALI_MODEL=vidore/colpali-v1.2

# ── CLIP visual similarity (optional) ─────────────────────────────────────────────
# Run scripts/index_visual.py to batch-index photos into the homeintel_visual
# collection for camera/photo-upload visual search.
CLIP_MODEL=openai/clip-vit-large-patch14
# When true, the watcher also CLIP-indexes new/changed images for live visual
# search. Run the bulk index_visual.py backfill first, then set this to true.
CLIP_AUTO_INDEX=false
# Use CLIP text->image search for image (text) queries — far better visual
# relevance than caption keyword matching. Falls back to captions if it returns nothing.
CLIP_TEXT_SEARCH=true
CLIP_TEXT_MIN_SCORE=0.2

# ── Security ──────────────────────────────────────────────────────────────────────
# Redact detected passwords / API keys / tokens / private keys from ingested
# chunks, LLM context, and source excerpts (replaced with <REDACTED>).
REDACT_SECRETS=true

# ── Dev helpers ───────────────────────────────────────────────────────────────────
# Skip the Ollama connectivity check on startup (useful for frontend-only dev).
SKIP_LLM_HEALTH_CHECK=false
