# ── NAS / File System ─────────────────────────────────────────────────────────
NAS_WATCH_PATH=/data/files          # path inside container (mount your NAS here)
SUPPORTED_EXTENSIONS=.pdf,.docx,.txt,.md,.png,.jpg,.jpeg,.mp3,.wav,.mp4,.mov
WATCHER_EXCLUDE_PATHS=/data/chroma,/docker,Z:/docker  # Docker Engine overlay2 storage on Windows hosts

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_PATH=/data/chroma            # persistent storage (mount your NAS here)
CHROMA_COLLECTION_NAME=homeintel

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_LLM_MODEL=qwen3.5:9b
OLLAMA_EMBED_MODEL=nomic-embed-text # dedicated embedding model (faster than LLM)

# ── RAG ───────────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
RETRIEVAL_TOP_K=6                   # number of chunks returned per query

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info                      # debug | info | warning | error

# ── Dev only ──────────────────────────────────────────────────────────────────
# Set to "true" to skip Ollama connection check on startup (useful for testing
# ingestion without a running LLM)
SKIP_LLM_HEALTH_CHECK=false