# ── NAS / File System ─────────────────────────────────────────────────────────
NAS_WATCH_PATH=/data/files
SUPPORTED_EXTENSIONS=.pdf,.docx,.txt,.md,.yml,.yaml,.json,.png,.jpg,.jpeg,.mp3,.wav
# Remove Music from WATCHER_EXCLUDE_PATHS if you want audio transcribed (slow — run overnight)
WATCHER_EXCLUDE_PATHS=/data/homeintel/qdrant_storage,/docker

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_URL=http://your-nas-ip:6333
QDRANT_COLLECTION_NAME=homeintel
QDRANT_API_KEY=                         # leave empty for no-auth LAN setup
EMBED_DIM=768

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434   # use http://host.docker.internal:11434 inside Docker
OLLAMA_LLM_MODEL=qwen3:14b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Image ingestion ───────────────────────────────────────────────────────────
# Set to a vision-capable Ollama model to enable image captioning.
# Leave empty to skip image files.
# Example: OLLAMA_VISION_MODEL=qwen2.5vl:7b
OLLAMA_VISION_MODEL=

# ── Audio ingestion ───────────────────────────────────────────────────────────
# faster-whisper model size: tiny|base|small|medium|large-v3
WHISPER_MODEL_SIZE=base

# ── CLIP visual similarity ────────────────────────────────────────────────────
# Run scripts/index_visual.py to batch-index photos into homeintel_visual collection.
# ~500 MB VRAM — safe to run alongside Ollama.
CLIP_MODEL=openai/clip-vit-large-patch14
# When true, the watcher also CLIP-indexes new/changed images for live visual
# search. Run the bulk index_visual.py backfill first, then set this to true.
CLIP_AUTO_INDEX=false

# ── ColPali visual retrieval ───────────────────────────────────────────────────
# Run scripts/run_colpali.py to batch-index PDFs, then set COLPALI_ENABLED=true.
# Requires: pip install colpali-engine>=0.3.0 pypdfium2>=4.0.0
COLPALI_ENABLED=false
COLPALI_MODEL=vidore/colpali-v1.2

# ── RAG ───────────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
RETRIEVAL_TOP_K=6
RERANKER_ENABLED=true
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# Image queries only: drop photos below this reranker relevance (0..1). Higher = stricter.
IMAGE_RERANK_MIN_SCORE=0.3
DOCLING_VLM_ENABLED=false
DOCLING_VLM_MODEL=Qwen/Qwen2.5-VL-7B-Instruct

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info

# ── Security ──────────────────────────────────────────────────────────────────
# Redact detected passwords / API keys / tokens / private keys from ingested
# chunks, LLM context, and source excerpts (replaced with <REDACTED>).
REDACT_SECRETS=true

# ── Dev only ──────────────────────────────────────────────────────────────────
SKIP_LLM_HEALTH_CHECK=false
